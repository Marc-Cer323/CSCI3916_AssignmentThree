{
  "info": {
    "name": "CSCI3916 HW3 - Movie API",
    "_postman_id": "csci3916-hw3-collection",
    "description": "Postman collection for CSCI3916 Assignment 3 - Movie API with JWT Authentication",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://csci3916-assignmentthree.onrender.com",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "random_username",
      "value": "",
      "type": "string"
    },
    {
      "key": "random_password",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup - New User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const randomStr = Math.random().toString(36).substring(2, 10);",
                  "const username = 'user_' + randomStr;",
                  "const password = 'pass_' + randomStr;",
                  "pm.collectionVariables.set('random_username', username);",
                  "pm.collectionVariables.set('random_password', password);",
                  "console.log('Generated username:', username);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Signup successful', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json.msg).to.include('Successfully created');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"username\": \"{{random_username}}\",\n  \"password\": \"{{random_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/signup",
              "host": ["{{base_url}}"],
              "path": ["signup"]
            }
          }
        },
        {
          "name": "Signin - Get JWT Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('JWT token returned', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json.token).to.exist;",
                  "    pm.collectionVariables.set('jwt_token', json.token);",
                  "    console.log('Token stored:', json.token.substring(0, 30) + '...');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{random_username}}\",\n  \"password\": \"{{random_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/signin",
              "host": ["{{base_url}}"],
              "path": ["signin"]
            }
          }
        },
        {
          "name": "Error - Duplicate User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 409', function () {",
                  "    pm.response.to.have.status(409);",
                  "});",
                  "pm.test('Duplicate user error returned', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.false;",
                  "    pm.expect(json.message).to.include('already exists');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"username\": \"{{random_username}}\",\n  \"password\": \"{{random_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/signup",
              "host": ["{{base_url}}"],
              "path": ["signup"]
            }
          }
        }
      ]
    },
    {
      "name": "Movies",
      "item": [
        {
          "name": "GET All Movies",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns array of movies', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "    pm.expect(json.length).to.be.at.least(1);",
                  "});",
                  "pm.test('Movies have required fields', function () {",
                  "    const json = pm.response.json();",
                  "    json.forEach(movie => {",
                  "        pm.expect(movie).to.have.property('title');",
                  "        pm.expect(movie).to.have.property('releaseDate');",
                  "        pm.expect(movie).to.have.property('genre');",
                  "        pm.expect(movie).to.have.property('actors');",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "{{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/movies",
              "host": ["{{base_url}}"],
              "path": ["movies"]
            }
          }
        },
        {
          "name": "GET Specific Movie",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns correct movie', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.title).to.equal('Inception');",
                  "    pm.expect(json.actors).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "{{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/movies/Inception",
              "host": ["{{base_url}}"],
              "path": ["movies", "Inception"]
            }
          }
        },
        {
          "name": "POST Save Movie",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Movie saved successfully', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json.movie.title).to.equal('Interstellar');",
                  "    pm.expect(json.movie.actors.length).to.be.at.least(3);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "{{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Interstellar\",\n  \"releaseDate\": 2014,\n  \"genre\": \"Science Fiction\",\n  \"actors\": [\n    { \"actorName\": \"Matthew McConaughey\", \"characterName\": \"Cooper\" },\n    { \"actorName\": \"Anne Hathaway\", \"characterName\": \"Brand\" },\n    { \"actorName\": \"Jessica Chastain\", \"characterName\": \"Murph\" }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/movies",
              "host": ["{{base_url}}"],
              "path": ["movies"]
            }
          }
        },
        {
          "name": "PUT Update Movie",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Movie updated successfully', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json.movie.genre).to.equal('Drama');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "{{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"genre\": \"Drama\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/movies/Interstellar",
              "host": ["{{base_url}}"],
              "path": ["movies", "Interstellar"]
            }
          }
        },
        {
          "name": "DELETE Movie",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Movie deleted successfully', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json.message).to.include('deleted');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "{{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/movies/Interstellar",
              "host": ["{{base_url}}"],
              "path": ["movies", "Interstellar"]
            }
          }
        },
        {
          "name": "Error - PUT on /movies (not allowed)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 405', function () {",
                  "    pm.response.to.have.status(405);",
                  "});",
                  "pm.test('Method not allowed error returned', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.false;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "{{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/movies",
              "host": ["{{base_url}}"],
              "path": ["movies"]
            }
          }
        },
        {
          "name": "Error - Missing Actors",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Error returned for missing actors', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.false;",
                  "    pm.expect(json.message).to.include('actors');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "{{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Bad Movie\",\n  \"releaseDate\": 2020,\n  \"genre\": \"Action\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/movies",
              "host": ["{{base_url}}"],
              "path": ["movies"]
            }
          }
        },
        {
          "name": "Error - Movie Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404', function () {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "pm.test('Movie not found error returned', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.false;",
                  "    pm.expect(json.message).to.include('not found');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "{{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/movies/MovieThatDoesNotExist",
              "host": ["{{base_url}}"],
              "path": ["movies", "MovieThatDoesNotExist"]
            }
          }
        }
      ]
    }
  ]
}
